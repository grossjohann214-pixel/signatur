{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "jest"],
    "noEmit": true,
    "rootDir": "../../",
    "baseUrl": "../../",
    "paths": {
      "@packages/*": ["packages/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../../packages/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
